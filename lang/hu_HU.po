#: ../udiskie/cli.py:46
#, python-brace-format
msgid "These options are mutually exclusive: {0}"
msgstr "Ezek az opciók kölcsönösen kizárják egymást: {0}"

#: ../udiskie/cli.py:119
msgid ""
"\n"
"    Note, that the options in the individual groups are mutually exclusive.\n"
"\n"
"    The config file can be a JSON or preferably a YAML file. For an\n"
"    example, see the MAN page (or doc/udiskie.8.txt in the repository).\n"
"    "
msgstr ""
"\n"
"    Megjegyzés: az egyes csoportokon belüli opciók kölcsönösen kizárják egymást.\n"
"\n"
"    A konfigurációs fájl lehet JSON, vagy inkább YAML formátumú. Példákért\n"
"    lásd a MAN oldalt (vagy a doc/udiskie.8.txt fájlt a repóban).\n"
"    "

#: ../udiskie/cli.py:139
#, python-format
msgid "%(message)s"
msgstr "%(message)s"

#: ../udiskie/cli.py:141
#, python-format
msgid "%(levelname)s [%(asctime)s] %(name)s: %(message)s"
msgstr "%(levelname)s [%(asctime)s] %(name)s: %(message)s"

#: ../udiskie/cli.py:386
msgid ""
"Typelib for 'libnotify' is not available. Possible causes include:\n"
"\t- libnotify is not installed\n"
"\t- the typelib is provided by a separate package\n"
"\t- libnotify was built with introspection disabled\n"
"\n"
"Starting udiskie without notifications."
msgstr ""
"A 'libnotify' typelib nem érhető el. Lehetséges okok:\n"
"\t- a libnotify nincs telepítve\n"
"\t- a typelib külön csomagban található\n"
"\t- a libnotify introspection támogatás nélkül lett fordítva\n"
"\n"
"Az udiskie értesítések nélkül indul."

#: ../udiskie/cli.py:400
msgid ""
"Not run within X or Wayland session.\n"
"Starting udiskie without tray icon.\n"
msgstr ""
"Nem X vagy Wayland munkamenetben fut.\n"
"Az udiskie tálcaikon nélkül indul.\n"

#: ../udiskie/cli.py:407
msgid ""
"Typelib for 'Gtk 3.0' is not available. Possible causes include:\n"
"\t- GTK3 is not installed\n"
"\t- the typelib is provided by a separate package\n"
"\t- GTK3 was built with introspection disabled\n"
"Starting udiskie without tray icon.\n"
msgstr ""
"A 'Gtk 3.0' typelib nem érhető el. Lehetséges okok:\n"
"\t- a GTK3 nincs telepítve\n"
"\t- a typelib külön csomagban található\n"
"\t- a GTK3 introspection támogatás nélkül lett fordítva\n"
"Az udiskie tálcaikon nélkül indul.\n"

#: ../udiskie/cli.py:417
msgid ""
"Typelib for 'AppIndicator3 0.1' is not available. Possible causes include:\n"
"\t- libappindicator is not installed\n"
"\t- the typelib is provided by a separate package\n"
"\t- it was built with introspection disabled\n"
"Starting udiskie without appindicator icon.\n"
msgstr ""
"Az 'AppIndicator3 0.1' typelib nem érhető el. Lehetséges okok:\n"
"\t- a libappindicator nincs telepítve\n"
"\t- a typelib külön csomagban található\n"
"\t- introspection támogatás nélkül lett fordítva\n"
"Az udiskie appindicator ikon nélkül indul.\n"

#: ../udiskie/cli.py:436
msgid ""
"The 'notify_command' option was renamed to 'event_hook'. The old name still "
"works, but may be removed in a future version. Please change your command "
"line and config to use the new name."
msgstr ""
"A 'notify_command' opció neve 'event_hook'-ra változott. A régi név még működik, "
"de a jövőben eltávolításra kerülhet. Kérjük, módosítsd a parancssort és a konfigurációt az új név használatára."

#: ../udiskie/cli.py:443
msgid "Ignoring 'notify_command' in favor of 'event_hook'."
msgstr "'notify_command' figyelmen kívül hagyva az 'event_hook' javára."

